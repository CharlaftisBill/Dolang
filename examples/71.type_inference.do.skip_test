fsum (lhs f32, rhs f32) f32 : {
    success lhs / rhs
}

nums_before_and_after (given_num i32) i32, i32 : {
    success given_num -1, given_num + 1
}

main () : {
    pi f32 : 3.14
    lucky_nums [3 i8] : [i8: 4, 7, 36]

    infer0 _ = 1
    infer1 _ = 1.2
    infer3 _ = "test"
    infer4 _ = true
    infer5 _ = 'a'
    infer6 _ = sum(1, 2)

    infer7 _ = (1.0 + (1.1 - 2.1) * 3.4) / 5.6
    infer8 _ = (1.0 + (fsum(0.6, 0.5) - (lucky_nums[1] / 4)) * pi) / 5.6

    infer9, infer10 _ = nums_before_and_after(5)

}