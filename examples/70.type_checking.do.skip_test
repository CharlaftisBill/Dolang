sum (lhs i32, rhs i32) i32 : {
    success lhs + rhs
}

nums_before_and_after (given_num i32) i32, i32 : {
    success given_num -1, given_num + 1
}

main () : {
    number_of_wonders i8 : 7
    pi f32 : 3.14
    lucky_nums [3 i8] : [i8: 4, 7, 36]

    invalid_declaration0 str = 1                    # cannot assign 'i32' value to 'str' variable
    invalid_declaration1 str = number_of_wonders    # cannot assign 'i8' value to 'str' variable

    number_of_wonders = 8    # cannot assign value to immutable variable

    my_age size = 30
    my_age = pi             # cannot assign 'f32' value to 'size' variable

    sum(0.1, 2)             # in function 'sum', argument 'lhs' is 'i32', but trying to assign a 'f32' value '0.1' to it
    sum(1, 0.2)             # in function 'sum', argument 'rhs' is 'i32', but trying to assign a 'f32' value '0.2' to it
    sum(1, 2, 3)            # in function 'sum', you are trying to pass '3' arguments but it can accept '2'

    my_sum f32 = sum(1, 2)  # cannot assign 'i32' value to 'f32' variable

    blah char   = 'ß'
    bloom i32   = 0

    blah, bloom = nums_before_and_after(3)   # cannot assign 'i32' value to 'char' variable
    bloom, blah = nums_before_and_after(3)   # cannot assign 'i32' value to 'char' variable
}